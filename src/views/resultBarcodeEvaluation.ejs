<%- include('partials/head', { pageTitle: 'Evaluation Results' }) %>
<%- include('partials/navbar', { user: user, activePage: 'upload' }) %>

<main class="page-content">
    <div class="container">

        <div class="header">
            <div>
                <h1>📊 Evaluation Results</h1>
                <p>Barcode: <strong><%= submission.roll_no %></strong> — <%= submission.student_name %></p>
            </div>
            <a href="/barcode-evaluation" class="btn btn-secondary">← Back</a>
        </div>

        <!-- Result Summary Card -->
        <div class="panel" style="margin-bottom: 1.5rem;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1.5rem; text-align: center;">

                <div>
                    <div style="font-size: 0.8rem; color: var(--color-text-2); margin-bottom: 0.3rem;">Student</div>
                    <div style="font-weight: 700; font-size: 1rem;"><%= submission.student_name %></div>
                </div>

                <div>
                    <div style="font-size: 0.8rem; color: var(--color-text-2); margin-bottom: 0.3rem;">Roll No</div>
                    <div style="font-weight: 700; font-size: 1rem;"><%= submission.roll_no %></div>
                </div>

                <div>
                    <div style="font-size: 0.8rem; color: var(--color-text-2); margin-bottom: 0.3rem;">Exam</div>
                    <div style="font-weight: 700; font-size: 1rem;"><%= submission.exam_name %></div>
                </div>

                <div>
                    <div style="font-size: 0.8rem; color: var(--color-text-2); margin-bottom: 0.3rem;">Subject</div>
                    <div style="font-weight: 700; font-size: 1rem;"><%= submission.subject %></div>
                </div>

                <div>
                    <div style="font-size: 0.8rem; color: var(--color-text-2); margin-bottom: 0.3rem;">Marks</div>
                    <div style="font-weight: 700; font-size: 1.2rem; color: var(--color-primary);">
                        <%= parseFloat(submission.total_marks_obtained || 0).toFixed(1) %> / <%= submission.exam_total_marks %>
                    </div>
                </div>

                <div>
                    <div style="font-size: 0.8rem; color: var(--color-text-2); margin-bottom: 0.3rem;">Percentage</div>
                    <div style="font-weight: 700; font-size: 1.2rem; color: var(--color-primary);">
                        <%= parseFloat(submission.percentage || 0).toFixed(1) %>%
                    </div>
                </div>

                <div>
                    <div style="font-size: 0.8rem; color: var(--color-text-2); margin-bottom: 0.3rem;">Result</div>
                    <div style="font-weight: 700; font-size: 1.2rem;">
                        <% if (parseFloat(submission.percentage || 0) >= 40) { %>
                            <span style="color: #16a34a;">✅ Pass</span>
                        <% } else { %>
                            <span style="color: #dc2626;">❌ Fail</span>
                        <% } %>
                    </div>
                </div>

            </div>
        </div>

        <!-- Per-Question Breakdown -->
        <div class="panel">
            <h3 style="margin-bottom: 1rem;">📝 Question-wise Breakdown</h3>

            <% if (answers && answers.length > 0) { %>
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
                    <thead>
                        <tr style="background: var(--color-bg-2);">
                            <th style="padding: 0.75rem 1rem; text-align: left; border-bottom: 2px solid var(--color-border);">Question</th>
                            <th style="padding: 0.75rem 1rem; text-align: left; border-bottom: 2px solid var(--color-border);">Student Answer</th>
                            <th style="padding: 0.75rem 1rem; text-align: center; border-bottom: 2px solid var(--color-border);">Marks Obtained</th>
                            <th style="padding: 0.75rem 1rem; text-align: center; border-bottom: 2px solid var(--color-border);">Max Marks</th>
                            <th style="padding: 0.75rem 1rem; text-align: center; border-bottom: 2px solid var(--color-border);">Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% answers.forEach(answer => { %>
                        <% const q = questionMap[answer.question_number] || {}; %>
                        <tr style="border-bottom: 1px solid var(--color-border);">
                            <td style="padding: 0.75rem 1rem; font-weight: 600;">
                                Q<%= answer.question_number %>
                                <% if (answer.is_or_question) { %>
                                    <span style="font-size: 0.75rem; color: #f59e0b; margin-left: 0.3rem;">OR</span>
                                <% } %>
                            </td>
                            <td style="padding: 0.75rem 1rem; color: var(--color-text-2); max-width: 350px;">
                                <div style="max-height: 80px; overflow-y: auto; white-space: pre-wrap; font-size: 0.8rem;">
                                    <%= answer.answer_text || '(no answer)' %>
                                </div>
                            </td>
                            <td style="padding: 0.75rem 1rem; text-align: center; font-weight: 700;">
                                <% const marksObtained = parseFloat(answer.marks_obtained || 0); %>
                                <% const maxMarks = parseFloat(q.max_marks || 0); %>
                                <span style="color: <%= marksObtained >= maxMarks * 0.5 ? '#16a34a' : '#dc2626' %>;">
                                    <%= marksObtained.toFixed(1) %>
                                </span>
                            </td>
                            <td style="padding: 0.75rem 1rem; text-align: center; color: var(--color-text-2);">
                                <%= q.max_marks || '—' %>
                            </td>
                            <td style="padding: 0.75rem 1rem; text-align: center;">
                                <span style="
                                    padding: 0.2rem 0.6rem;
                                    border-radius: 999px;
                                    font-size: 0.75rem;
                                    font-weight: 600;
                                    background: <%= q.question_type === 'short' ? '#dbeafe' : '#fef3c7' %>;
                                    color: <%= q.question_type === 'short' ? '#1d4ed8' : '#92400e' %>;
                                ">
                                    <%= q.question_type || '—' %>
                                </span>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div style="text-align: center; padding: 2rem; color: var(--color-text-2);">
                No question answers found.
            </div>
            <% } %>
        </div>

        <!-- Action Buttons -->
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
            <a href="/barcode-evaluation" class="btn btn-secondary">
                ← Evaluate Another
            </a>
            <a href="/history" class="btn btn-primary">
                📋 View All Results
            </a>
        </div>

    </div>
</main>

<%- include('partials/footer') %>
